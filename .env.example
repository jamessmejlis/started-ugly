# Canonical site URL (drives metadataBase, sitemap, OG absolute URLs)
NEXT_PUBLIC_SITE_URL=https://shittyfirstdrafts.directory

# Server-side newsletter capture. The /api/subscribe route files one GitHub issue
# per signup into a PRIVATE repo (emails never touch the public repo). Create a
# fine-grained PAT scoped to ONLY that repo with Issues: read & write.
SIGNUPS_REPO=jamessmejlis/sfd-signups
SIGNUPS_GH_TOKEN=

# Submissions go through GitHub Issues (the submit form opens a pre-filled issue
# on the public repo), so no extra keys are needed for that path.
